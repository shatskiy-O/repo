# =============================================================================
# callstats-grafana — пример конфигурации
# Скопируйте в .env и заполните под свою инсталляцию. .env в git не коммитится.
# =============================================================================

# ---------- АТС (FreePBX / Asterisk) ----------
ATS_HOST=ats.example.local            # IP или FQDN АТС
ATS_SSH_PORT=22
ATS_SSH_USER=grafana                  # Linux-пользователь для SSH-туннеля

# MariaDB на АТС
ATS_MYSQL_HOST=127.0.0.1              # локальный адрес MariaDB на АТС
ATS_MYSQL_PORT=3306

# Пользователи БД, создаются 01_schema.sql
CALLSTATS_DB=callstats
CALLSTATS_WRITER_USER=callstats_writer
CALLSTATS_WRITER_PASS=CHANGE_ME       # пароль для ETL
CALLSTATS_RO_USER=callstats_ro
CALLSTATS_RO_PASS=CHANGE_ME           # пароль для Grafana (read-only)

# ---------- VM с Grafana ----------
GF_HOST_IP=10.0.0.0                   # IP VM с Grafana (для документации)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME           # начальный admin-пароль
GF_LOCAL_TUNNEL_PORT=3307             # локальный порт на VM, куда пробрасывается MySQL АТС
GF_DATASOURCE_UID=PC8CDFBD862B3D820   # UID datasource; менять только если нужно

# Путь к приватному SSH-ключу на VM (файл держим ВНЕ репозитория)
GF_SSH_KEY_PATH=/home/tor/.ssh/ats_grafana_rsa
