          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(TIMESTAMPDIFF(SECOND, enter_ts, connect_ts)),2) AS value FROM queue_calls WHERE $__timeFilter(enter_ts) AND queuename LIKE '${queue:raw}' AND (agent LIKE '${agent:raw}' OR agent IS NULL OR agent = '') AND disposition='ANSWERED'",
